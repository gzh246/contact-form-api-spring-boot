# Recommended QQ Mail configuration using an SMTP authorization code.
# Copy this file to smtp.local.env. That filename is ignored by Git.
# Never use or store the normal mailbox login password here.
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
APP_MAIL_ENABLED=true
SMTP_USERNAME=your-address@qq.com
SMTP_PASSWORD=replace-with-smtp-authorization-code
SMTP_AUTH=true
SMTP_SSL=true
SMTP_STARTTLS=false
CONTACT_MAIL_FROM=your-address@qq.com
CONTACT_MAIL_TO=your-notification-address@example.com
CONTACT_MAIL_SUBJECT_PREFIX=[Contact API Demo]

# For QQ Mail port 587 instead, use SMTP_SSL=false and SMTP_STARTTLS=true.
# For 163 Mail, change SMTP_HOST to smtp.163.com and use the provider's SMTP authorization code.
